@st.cache_data
def load_data():
    """Load and preprocess the dataset"""
    df = pd.read_csv('data/Ecommerce.csv')
    
    # Parse date
    df['visit_date'] = pd.to_datetime(df['visit_date'], format='%d-%m-%Y')
    df['visit_year'] = df['visit_date'].dt.year
    df['visit_quarter'] = df['visit_date'].dt.quarter
    
    # Create price tiers
    df['price_tier'] = pd.cut(df['unit_price'], 
                               bins=[0, 300, 700, 1200, 2000],
                               labels=['Low', 'Medium', 'High', 'Premium'])
    
    # Income proxy
    df['revenue_per_unit'] = df['revenue'] / (df['quantity'] + 0.001)
    df['revenue_per_unit'] = df['revenue_per_unit'].replace([np.inf, -np.inf], 0)
    
    # Engagement score
    df['engagement_score'] = (df['pages_viewed'] / 24) * 0.4 + \
                              (df['time_on_site_sec'] / 1800) * 0.4 + \
                              (df['added_to_cart']) * 0.2
    
    # Discount intensity
    df['discount_intensity'] = df['discount_percent'] / 100
    
    # Location tier (Age/Demographic proxy)
    df['location_tier'] = pd.cut(df['location'], 
                                  bins=[0, 50, 100, 150, 225],
                                  labels=['Tier1', 'Tier2', 'Tier3', 'Tier4'])
    
    # Team (Product Category as team indicator)
    df['team'] = df['product_category'].map({
        0: 'Team_A', 1: 'Team_B', 2: 'Team_C', 3: 'Team_D',
        4: 'Team_E', 5: 'Team_F', 6: 'Team_G', 7: 'Team_H'
    })
    
    # Mappings
    df['marketing_channel_name'] = df['marketing_channel'].map({
        0: 'Organic', 1: 'Email', 2: 'Social', 3: 'Paid Ads', 4: 'Referral', 5: 'Direct'
    })
    df['device_type_name'] = df['device_type'].map({0: 'Desktop', 1: 'Mobile', 2: 'Tablet'})
    df['user_type_name'] = df['user_type'].map({0: 'New', 1: 'Returning'})
    
    return df

@st.cache_data
def train_models(df):
    """Train all classification models"""
    feature_cols = ['device_type', 'user_type', 'marketing_channel', 'product_category',
                    'unit_price', 'quantity', 'discount_percent', 'pages_viewed', 
                    'time_on_site_sec', 'added_to_cart', 'cart_abandoned', 'rating',
                    'review_helpful_votes', 'visit_day', 'visit_month', 'visit_weekday',
                    'visit_season', 'revenue_normalized', 'location',
                    'engagement_score', 'discount_intensity']
    
    X = df[feature_cols].fillna(df[feature_cols].median())
    y = df['purchased']
    
    X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.25, random_state=42, stratify=y)
    
    scaler = StandardScaler()
    X_train_scaled = scaler.fit_transform(X_train)
    X_test_scaled = scaler.transform(X_test)
    
    models = {
        'KNN': KNeighborsClassifier(n_neighbors=5, weights='uniform'),
        'Decision Tree': DecisionTreeClassifier(max_depth=10, min_samples_split=50, random_state=42),
        'Random Forest': RandomForestClassifier(n_estimators=200, max_depth=15, min_samples_split=20, 
                                                 random_state=42, n_jobs=-1),
        'Gradient Boosting': GradientBoostingClassifier(n_estimators=200, max_depth=5, learning_rate=0.1,
                                                         random_state=42)
    }
    
    results = {}
    cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)
    
    for name, model in models.items():
        if name == 'KNN':
            model.fit(X_train_scaled, y_train)
            y_pred = model.predict(X_test_scaled)
            y_prob = model.predict_proba(X_test_scaled)[:, 1]
            cv_scores = cross_val_score(model, X_train_scaled, y_train, cv=cv, scoring='accuracy')
        else:
            model.fit(X_train, y_train)
            y_pred = model.predict(X_test)
            y_prob = model.predict_proba(X_test)[:, 1]
            cv_scores = cross_val_score(model, X_train, y_train, cv=cv, scoring='accuracy')
        
        fpr, tpr, _ = roc_curve(y_test, y_prob)
        roc_auc = auc(fpr, tpr)
        precision_curve, recall_curve, _ = precision_recall_curve(y_test, y_prob)
        avg_precision = average_precision_score(y_test, y_prob)
        
        results[name] = {
            'model': model,
            'accuracy': accuracy_score(y_test, y_pred),
            'precision': precision_score(y_test, y_pred),
            'recall': recall_score(y_test, y_pred),
            'f1': f1_score(y_test, y_pred),
            'cv_mean': cv_scores.mean(),
            'cv_std': cv_scores.std(),
            'fpr': fpr, 'tpr': tpr, 'roc_auc': roc_auc,
            'precision_curve': precision_curve, 'recall_curve': recall_curve,
            'avg_precision': avg_precision,
            'cm': confusion_matrix(y_test, y_pred),
            'y_test': y_test, 'y_pred': y_pred, 'y_prob': y_prob
        }
    
    return results, X, y

